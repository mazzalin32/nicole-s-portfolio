// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model HeroContent {
  id                String   @id @default(cuid())
  headline          String   @default("HI, I'm Nicole")
  subtitle          String?  @default("Experienced Virtual Assistant dedicated to streamlining your business operations.")
  ctaText           String   @default("Work With Me")
  imageUrl          String?  @default("/nicole-hero.png")
  secondaryImageUrl String?  @default("/nicole-hero-2.png")
  studentsCount     String?  @default("100+")
  roleTitle         String?  @default("Expert Virtual Assistant")
  roleSubtitle      String?  @default("Strategic Business Partner")
  updatedAt         DateTime @default(now()) @updatedAt
}

model AboutContent {
  id                String   @id @default(cuid())
  introLine         String   @default("Hey, I'm Nicole")
  headline          String   @default("Expert Virtual Assistant & Strategic Partner")
  description       String   @default("...")
  ctaText           String   @default("Work With Me")
  imageUrl          String?  @default("/nicole-about.png")
  secondaryImageUrl String?  @default("/nicole-about-2.png")
  quote             String?  @default("...")
  updatedAt         DateTime @default(now()) @updatedAt
}

model Service {
  id          String           @id @default(cuid())
  title       String
  description String
  iconName    String?          // Store Lucide icon name
  order       Int              @default(0)
  features    ServiceFeature[]
}

model ServiceFeature {
  id        String  @id @default(cuid())
  text      String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String
}

model Skill {
  id          String  @id @default(cuid())
  name        String
  description String?
  level       Int     @default(0) // For technical skills
  category    String  // "Creative" or "Technical"
  order       Int     @default(0)
}

model Platform {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
}

model Value {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int     @default(0)
}

model SiteSettings {
  id           String       @id @default(cuid())
  ownerName    String
  contactEmail String
  phoneNumber  String?
  instagramUrl String?
  socialLinks  SocialLink[]
}

model SocialLink {
  id             String       @id @default(cuid())
  platform       String
  url            String
  iconName       String?
  order          Int          @default(0)
  siteSettings   SiteSettings @relation(fields: [siteSettingsId], references: [id], onDelete: Cascade)
  siteSettingsId String
}


model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model PodcastEpisode {
  id          String   @id @default(cuid())
  title       String
  description String
  audioUrl    String
  createdAt   DateTime @default(now())
}
