// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model HeroContent {
  id            String  @id @default(cuid())
  headline      String
  subtitle      String
  ctaText       String
  imageUrl      String?
  studentsCount String?
  roleTitle     String?
  roleSubtitle  String?
}

model AboutContent {
  id          String  @id @default(cuid())
  introLine   String
  headline    String
  description String
  ctaText     String
  imageUrl    String?
  quote       String?
}

model Service {
  id          String           @id @default(cuid())
  title       String
  description String
  iconName    String?          // Store Lucide icon name
  order       Int              @default(0)
  features    ServiceFeature[]
}

model ServiceFeature {
  id        String  @id @default(cuid())
  text      String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String
}

model Skill {
  id          String  @id @default(cuid())
  name        String
  description String?
  level       Int     @default(0) // For technical skills
  category    String  // "Creative" or "Technical"
  order       Int     @default(0)
}

model Platform {
  id    String @id @default(cuid())
  name  String
  order Int    @default(0)
}

model Value {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int     @default(0)
}

model SiteSettings {
  id           String  @id @default(cuid())
  ownerName    String
  contactEmail String
  phoneNumber  String?
  instagramUrl String?
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model PodcastEpisode {
  id          String   @id @default(cuid())
  title       String
  description String
  audioUrl    String
  createdAt   DateTime @default(now())
}
